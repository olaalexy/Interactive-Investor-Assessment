    "@wdio/globals": "^9.16.0",
    "@wdio/local-runner": "^9.16.0",
    "@wdio/types": "^9.16.0",
    "chromedriver": "^135.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wdio-json-html-reporter": "^1.5.14"
  }
}
